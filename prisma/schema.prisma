generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScheduleType {
  DAILY
  WEEKLY
  WEEKDAY
  WEEKEND
  AMPM
  HOURLY
}

enum ReportStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id            String                @id @default(cuid())
  name          String?
  email         String?               @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  schedules     CategoryScheduleSet[]
  reports       Report[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  oauth_token_secret String?
  oauth_token       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CategoryScheduleSet {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainCategory      String
  mainCustom        String?
  subCategory       String
  subCustom         String?
  scheduleType      ScheduleType
  timezone          String       @default("Asia/Seoul")
  dayOfWeek         Int?
  hour              Int?
  minute            Int          @default(0)
  intervalHours     Int?
  morningHour       Int?
  eveningHour       Int?
  sendToDiscord     Boolean      @default(false)
  aiPerspective     Boolean      @default(false)
  summary           String
  nextRunAt         DateTime?
  lastRunAt         DateTime?
  createdAt         DateTime     @default(now())
  reports           Report[]

  @@index([userId, nextRunAt])
}

model Report {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  setId           String?
  scheduleSet     CategoryScheduleSet? @relation(fields: [setId], references: [id], onDelete: SetNull)
  title           String
  markdown        String
  ttsText         String
  ttsPath         String?
  sourceItems     String              @default("[]")
  status          ReportStatus        @default(PENDING)
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([setId, createdAt])
}
